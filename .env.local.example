# Supabase (proyecto en supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://xxxxxxxxxxxx.supabase.co/auth/v1/.well-known/jwks.json
# Clave service_role (server-only, bypassea RLS): usada por
# lib/supabase/admin.ts para leer auth.users y crear notifications al
# editar/eliminar un evento. Nunca exponerla al cliente ni versionarla con
# un valor real.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (resend.com > API Keys): envío de emails de notificación.
# En desarrollo, Resend con una cuenta sin dominio verificado solo permite
# enviar al email de la propia cuenta de Resend.
RESEND_API_KEY=your-resend-api-key

# Email que recibe el aviso interno de "nuevo mensaje de contacto"
# (app/[locale]/contacto). Opcional: si no está definida, solo se guarda en
# la tabla contact_messages y se envía la confirmación al remitente.
CONTACT_TEAM_EMAIL=team@example.com

# Origen público del sitio, usado para construir enlaces absolutos en los
# emails de notificación. En producción, la URL real del deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
